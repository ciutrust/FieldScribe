# Copy to .env (repo root) — read by both the Next app and the Python worker.

# HuggingFace read token for the gated pyannote diarization models.
# 1. Create a free account at huggingface.co
# 2. Accept terms at huggingface.co/pyannote/speaker-diarization-3.1
#    AND huggingface.co/pyannote/segmentation-3.0
# 3. Create a read token at huggingface.co/settings/tokens
HF_TOKEN=

# Anthropic API key — used only for the summary + action items step.
ANTHROPIC_API_KEY=

# Cloud sync (v2): your FieldNotes login — the cloud library shares that
# Supabase project. If unset, sync falls back to /Users/ac/fieldnotes/.env.local.
FIELDSCRIBE_SYNC_EMAIL=
FIELDSCRIBE_SYNC_PASSWORD=

# Optional overrides
# WHISPER_MODEL=mlx-community/whisper-large-v3-turbo   # or mlx-community/whisper-large-v3-mlx for max accuracy
# FIELDSCRIBE_DATA_DIR=/Users/ac/fieldscribe/data
# WORKER_POLL_SECONDS=2
