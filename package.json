{
  "name": "fieldscribe",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n web,worker,sync -c blue,magenta,yellow \"npm run -s dev:web\" \"npm run -s worker\" \"npm run -s sync:watch\"",
    "dev:web": "next dev -p 3010",
    "worker": "cd worker && uv run python worker.py",
    "sync": "node scripts/sync.mjs",
    "sync:watch": "node scripts/sync.mjs --watch",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:worker": "cd worker && uv run pytest -q"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.1",
    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.23.0",
    "next": "16.2.10",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.6.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "shadcn": "^4.13.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^10.0.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
